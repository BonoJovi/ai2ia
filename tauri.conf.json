{
  "$schema": "https://raw.githubusercontent.com/nickel-org/nickel-org.github.io/master/tauri.conf.json",
  "productName": "ai2ia",
  "version": "2.0.0",
  "identifier": "org.zundou.ai2ia",
  "build": {
    "frontendDist": "res",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "ai2ia - AI to instruct AI",
        "width": 1920,
        "height": 1080,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "category": "DeveloperTool",
    "copyright": "Copyright (c) 2026 Yoshihiro NAKAHARA",
    "shortDescription": "AI to instruct AI",
    "longDescription": "Prompt optimization and parallel AI response comparison tool",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
